<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#FFFFFF" android:padding="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#F8F9FA" android:padding="10dp"
        android:elevation="3dp" android:layout_marginBottom="12dp">
        <View android:id="@+id/statusColorBar" android:layout_width="match_parent" android:layout_height="6dp" android:background="#CCCCCC" />
        <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="INITIALIZING SCANNER..." android:gravity="center" android:padding="8dp"
            android:textStyle="bold" android:textColor="#333" android:textSize="16sp" />
    </LinearLayout>

    <TextView android:id="@+id/tvOp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Operator" android:textSize="18sp" android:textStyle="bold" android:textColor="#1A73E8"/>
    <TextView android:id="@+id/tvRat" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RAT" android:textColor="#555"/>
    <TextView android:id="@+id/tvLoc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="GPS: 0.0, 0.0" android:textSize="12sp"/>
    <TextView android:id="@+id/tvTime" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Update: --" android:textSize="10sp" android:layout_marginBottom="8dp"/>

    <GridLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:columnCount="2">
        <TextView android:id="@+id/s1" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s2" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s3" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s4" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s5" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s6" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s7" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
        <TextView android:id="@+id/s8" android:layout_columnWeight="1" android:background="#F1F3F4" android:padding="12dp" android:layout_margin="1dp" android:text="-" android:gravity="center" android:textSize="13sp"/>
    </GridLayout>

    <Button android:id="@+id/btnStart" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RESUME MONITOR" android:backgroundTint="#4CAF50"/>
    <Button android:id="@+id/btnStop" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PAUSE VIEW (LOGGING CONTINUES)" android:backgroundTint="#FF9800"/>
    <Button android:id="@+id/btnHistory" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="FULL DATA LOGS" android:backgroundTint="#1976D2"/>
</LinearLayout>